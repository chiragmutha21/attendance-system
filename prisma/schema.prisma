generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public"]
}

model AdminUser {
  id           String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authUserId   String          @unique @map("auth_user_id") @db.Uuid
  email        String          @unique
  name         String?         @map("full_name")
  role         String          @default("company_admin")
  status       String          @default("active")
  createdAt    DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  companies    Company[]
  employees    Employee[]

  @@index([email], map: "idx_authentication_email")
  @@map("authentication")
  @@schema("public")
}

model Company {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String             @map("company_name")
  companyCode          String?            @unique @map("company_code")
  adminAuthId          String?            @map("admin_auth_id") @db.Uuid
  adminName            String             @map("admin_name")
  adminEmail           String             @map("admin_email")
  adminPhone           String             @map("admin_phone")
  countryCode          String             @default("+91") @map("country_code")
  employeeLimit        Int                @default(25) @map("employee_limit")
  subscription         String             @default("trial")
  status               String             @default("active")
  officeLatitude       Float?             @map("office_latitude")
  officeLongitude      Float?             @map("office_longitude")
  officeRadiusMeters   Int                @default(200) @map("office_radius_meters")
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime           @default(now()) @map("updated_at") @db.Timestamptz(6)
  adminUser            AdminUser?         @relation(fields: [adminAuthId], references: [id], onUpdate: NoAction)
  employees            Employee[]
  AttendanceLink       AttendanceLink[]
  AttendanceRecord     AttendanceRecord[]
  festivals            Festival[]
  branches             Branch[]

  @@index([adminAuthId], map: "idx_company_admin_auth_id")
  @@map("company_details")
  @@schema("public")
}

model Employee {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId           String          @map("company_id") @db.Uuid
  companyName         String          @default("Demo Company") @map("company_name")
  employeeId          String          @map("employee_id")
  fullName            String          @map("full_name")
  mobileNumber        String          @map("mobile_number")
  department          String
  role                String          @map("designation_role")
  status              String          @default("active")
  registeredFaceImage String?         @map("registered_face_image")
  addedByAuthId       String?         @map("added_by_auth_id") @db.Uuid
  createdAt           DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime        @default(now()) @map("updated_at") @db.Timestamptz(6)
  adminUser           AdminUser?      @relation(fields: [addedByAuthId], references: [id], onUpdate: NoAction)
  company             Company         @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  assignedBranchIds   String[]        @default([])

  @@unique([companyId, employeeId])
  @@unique([companyId, mobileNumber])
  @@index([companyId], map: "idx_employee_company_id")
  @@index([mobileNumber], map: "idx_employee_mobile_number")
  @@map("employee_details")
  @@schema("public")
}



model AttendanceLink {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String   @db.Uuid
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employeeId String
  token      String   @unique
  expiresAt  DateTime @db.Timestamptz(6)
  used       Boolean  @default(false)
  createdAt  DateTime @default(now()) @db.Timestamptz(6)

  @@index([companyId])
  @@schema("public")
}

model AttendanceRecord {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String   @db.Uuid
  company            Company  @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  employeeId         String
  employeeName       String
  selfieUrl          String
  latitude           Float
  longitude          Float
  accuracy           Float
  distanceFromOffice Float
  status             String
  type               String   @default("check-in")
  checkInTime        DateTime @default(now()) @db.Timestamptz(6)
  timezone           String
  deviceInfo         String
  address            String?
  branchId           String?  @db.Uuid
  branchName         String?
  distanceFromBranch Float?

  @@index([companyId])
  @@schema("public")
}

model Festival {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  name      String
  date      String   // ISO date string "YYYY-MM-DD"
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([companyId, date])
  @@map("company_festivals")
  @@schema("public")
}

model Branch {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade, onUpdate: NoAction)
  name         String
  address      String?
  latitude     Float
  longitude    Float
  radiusMeters Int      @default(200)
  isMainOffice Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@index([companyId])
  @@map("company_branches")
  @@schema("public")
}

